// ============================================================
//  Jenkinsfile — DevOps Transformation Pipeline
//  Author : Swanand Awatade | Binary Hat Pvt. Ltd.
//  Result : 40% faster time-to-market for new features
//  Stack  : Docker + Ansible + Prometheus + Grafana
// ============================================================

pipeline {
    agent any

    environment {
        APP_NAME       = "retail-platform"
        APP_VERSION    = "1.0.${BUILD_NUMBER}"
        IMAGE_NAME     = "${APP_NAME}:${BUILD_NUMBER}"
        IMAGE_LATEST   = "${APP_NAME}:latest"
        REGISTRY       = credentials("DOCKER_REGISTRY")
        REGISTRY_CREDS = "docker-registry-credentials"
        DEPLOY_HOST    = credentials("DEPLOY_HOST_IP")
        DEPLOY_USER    = "ec2-user"
        APP_PORT       = "8080"
        GRAFANA_URL    = "http://${DEPLOY_HOST}:3000"
        PROMETHEUS_URL = "http://${DEPLOY_HOST}:9090"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: "10"))
        timestamps()
        timeout(time: 45, unit: "MINUTES")
        disableConcurrentBuilds()
        ansiColor("xterm")
    }

    triggers {
        githubPush()
    }

    stages {

        // ── 1. Checkout ─────────────────────────────────────
        stage("Checkout") {
            steps {
                echo "📦 Checking out source..."
                checkout scm
                script {
                    env.GIT_COMMIT_SHORT = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()
                    env.GIT_BRANCH_NAME = sh(
                        script: "git rev-parse --abbrev-ref HEAD",
                        returnStdout: true
                    ).trim()
                }
                echo "Branch: ${env.GIT_BRANCH_NAME} | Commit: ${env.GIT_COMMIT_SHORT}"
            }
        }

        // ── 2. Lint ─────────────────────────────────────────
        stage("Lint") {
            steps {
                echo "🔍 Running linters..."
                sh """
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install --quiet flake8 pylint
                    flake8 app/src/ --max-line-length=120 --exclude=venv \
                        --format='%(path)s:%(row)d:%(col)d: %(code)s %(text)s'
                    echo "✅ Linting passed"
                """
            }
        }

        // ── 3. Unit Tests ────────────────────────────────────
        stage("Unit Tests") {
            steps {
                echo "🧪 Running unit tests..."
                sh """
                    . venv/bin/activate
                    pip install --quiet -r app/requirements.txt
                    python -m pytest app/tests/ \
                        -v \
                        --tb=short \
                        --cov=app/src \
                        --cov-report=xml:coverage.xml \
                        --cov-report=html:htmlcov \
                        --cov-fail-under=80 \
                        --junitxml=test-results.xml
                """
            }
            post {
                always {
                    junit "test-results.xml"
                    publishHTML(target: [
                        reportDir:   "htmlcov",
                        reportFiles: "index.html",
                        reportName:  "Coverage Report",
                        keepAll:     true
                    ])
                }
            }
        }

        // ── 4. Build Docker Image ────────────────────────────
        stage("Build Docker Image") {
            steps {
                echo "🐳 Building Docker image: ${IMAGE_NAME}"
                sh """
                    docker build \
                        --build-arg APP_VERSION=${APP_VERSION} \
                        --build-arg BUILD_NUMBER=${BUILD_NUMBER} \
                        --label git.commit=${GIT_COMMIT_SHORT} \
                        --label build.number=${BUILD_NUMBER} \
                        -f docker/Dockerfile \
                        -t ${IMAGE_NAME} \
                        -t ${IMAGE_LATEST} \
                        .
                    echo "✅ Image built: ${IMAGE_NAME}"
                    docker images ${APP_NAME}
                """
            }
        }

        // ── 5. Security Scan ─────────────────────────────────
        stage("Security Scan") {
            steps {
                echo "🔐 Scanning image with Trivy..."
                sh """
                    docker run --rm \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        -v \$HOME/.cache:/root/.cache \
                        aquasec/trivy:latest image \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        ${IMAGE_NAME}
                    echo "✅ Security scan complete"
                """
            }
        }

        // ── 6. Push to Registry ──────────────────────────────
        stage("Push Image") {
            when { branch "main" }
            steps {
                echo "📤 Pushing image to registry..."
                withCredentials([usernamePassword(
                    credentialsId: REGISTRY_CREDS,
                    usernameVariable: "DOCKER_USER",
                    passwordVariable: "DOCKER_PASS"
                )]) {
                    sh """
                        echo "\$DOCKER_PASS" | docker login ${REGISTRY} -u "\$DOCKER_USER" --password-stdin
                        docker tag ${IMAGE_NAME}   ${REGISTRY}/${IMAGE_NAME}
                        docker tag ${IMAGE_LATEST} ${REGISTRY}/${IMAGE_LATEST}
                        docker push ${REGISTRY}/${IMAGE_NAME}
                        docker push ${REGISTRY}/${IMAGE_LATEST}
                        docker logout ${REGISTRY}
                        echo "✅ Pushed: ${REGISTRY}/${IMAGE_NAME}"
                    """
                }
            }
        }

        // ── 7. Deploy with Ansible ───────────────────────────
        stage("Deploy (Ansible)") {
            when { branch "main" }
            steps {
                echo "🚀 Deploying with Ansible..."
                withCredentials([sshUserPrivateKey(
                    credentialsId: "deploy-ssh-key",
                    keyFileVariable: "SSH_KEY"
                )]) {
                    sh """
                        chmod 600 \$SSH_KEY
                        ansible-playbook \
                            -i ansible/inventory/production.ini \
                            ansible/deploy.yml \
                            --private-key=\$SSH_KEY \
                            --extra-vars "app_version=${APP_VERSION} \
                                          build_number=${BUILD_NUMBER} \
                                          image_name=${REGISTRY}/${IMAGE_NAME} \
                                          deploy_env=production" \
                            -v
                    """
                }
            }
        }

        // ── 8. Smoke Test ────────────────────────────────────
        stage("Smoke Test") {
            when { branch "main" }
            steps {
                echo "💨 Running smoke tests..."
                sh """
                    sleep 15
                    for i in \$(seq 1 8); do
                        STATUS=\$(curl -s -o /dev/null -w "%{http_code}" \
                            "http://${DEPLOY_HOST}:${APP_PORT}/health" || echo "000")
                        if [ "\$STATUS" = "200" ]; then
                            echo "✅ Smoke test PASSED (HTTP \$STATUS)"
                            exit 0
                        fi
                        echo "⏳ Attempt \$i/8 — HTTP \$STATUS"
                        sleep 10
                    done
                    echo "❌ Smoke test FAILED"
                    exit 1
                """
            }
        }

        // ── 9. Verify Monitoring ─────────────────────────────
        stage("Verify Monitoring") {
            when { branch "main" }
            steps {
                echo "📊 Verifying Prometheus + Grafana..."
                sh """
                    # Check Prometheus is scraping the app
                    sleep 30
                    PROM_STATUS=\$(curl -s "${PROMETHEUS_URL}/api/v1/targets" | \
                        python3 -c "import sys,json; targets=json.load(sys.stdin)['data']['activeTargets']; \
                        app=[t for t in targets if 'retail-app' in t.get('labels',{}).get('job','')]; \
                        print('up' if app and app[0]['health']=='up' else 'down')")
                    echo "Prometheus target status: \$PROM_STATUS"

                    # Check Grafana is up
                    GRAF_STATUS=\$(curl -s -o /dev/null -w "%{http_code}" "${GRAFANA_URL}/api/health")
                    echo "Grafana status: HTTP \$GRAF_STATUS"
                """
            }
        }
    }

    post {
        success {
            echo """
            ================================================
            ✅ PIPELINE SUCCEEDED
            App     : ${APP_NAME}
            Version : ${APP_VERSION}
            Build   : #${BUILD_NUMBER}
            Commit  : ${env.GIT_COMMIT_SHORT}
            Branch  : ${env.GIT_BRANCH_NAME}
            App URL : http://${DEPLOY_HOST}:${APP_PORT}
            Grafana : http://${DEPLOY_HOST}:3000
            Prometheus: http://${DEPLOY_HOST}:9090
            ================================================
            """
        }
        failure {
            echo "❌ Pipeline FAILED — check logs above"
        }
        always {
            sh "docker rmi ${IMAGE_NAME} ${IMAGE_LATEST} || true"
            sh "rm -rf venv htmlcov || true"
            cleanWs(cleanWhenNotBuilt: false, cleanWhenFailure: false)
        }
    }
}
